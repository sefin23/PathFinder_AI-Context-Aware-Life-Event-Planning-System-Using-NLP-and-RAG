{
  "version": "2026-03-15",
  "meta": {
    "description": "Portal registry for Pathfinder: state portals, URN patterns, prerequisites, and timeline buffers",
    "default_timeline_days": {
      "short": 7,
      "medium": 21,
      "long": 45
    }
  },

  "urn_patterns": {
    "aadhaar_update": {
      "label_keywords": ["URN", "Update Request Number"],
      "regex": "\\b\\d{4}/\\d{5}/\\d{5}\\b",
      "source": "UIDAI update slips and PDFs"
    },
    "pan_application": {
      "label_keywords": ["Acknowledgement Number", "15 digit acknowledgement"],
      "regex": "\\b\\d{15}\\b",
      "source": "NSDL/Protean PAN acknowledgement receipts"
    },
    "epfo_claim": {
      "label_keywords": ["Claim Reference Number", "Tracking ID", "PF Claim ID"],
      "regex": "\\b[A-Z0-9/\\-]{10,30}\\b",
      "source": "EPFO claim/transfer receipts"
    },
    "generic_portal_ref": {
      "label_keywords": ["Reference No", "Application No", "Reference ID"],
      "regex": "\\b[A-Z0-9\\-]{8,20}\\b",
      "source": "State e-district / seva receipts"
    }
  },

  "timeline_buffers": {
    "aadhaar_update": {
      "first_followup_days": 7,
      "second_followup_days": 14
    },
    "pan_change": {
      "first_followup_days": 10,
      "second_followup_days": 20
    },
    "voter_address_change": {
      "first_followup_days": 21,
      "second_followup_days": 35
    },
    "dl_address_change": {
      "first_followup_days": 21,
      "second_followup_days": 45
    },
    "epf_transfer": {
      "first_followup_days": 10,
      "second_followup_days": 21
    },
    "domicile_certificate": {
      "first_followup_days": 14,
      "second_followup_days": 30
    }
  },

  "prerequisite_tags": {
    "id_proof_standard": ["aadhaar", "pan", "voter_id", "passport", "driving_licence"],
    "address_proof_standard": ["ration_card", "electricity_bill", "water_bill", "property_tax_receipt", "rent_agreement"],
    "education_records_long_stay": ["school_leaving_certificate", "ssc_hsc_marksheets", "college_tc"],
    "domicile_affidavit": ["notarized_affidavit_domicile_period"],
    "employment_proof": ["offer_letter", "salary_slip", "form16"],
    "vehicle_relocation": ["rc_book", "insurance", "puc", "loan_noc_if_hypothecated"],
    "offline_rent_ka_mh": ["stamp_vendor_visit", "printed_rent_agreement"]
  },

  "states": {
    "KA": {
      "name": "Karnataka",
      "pattern": "unified_seva",
      "job_cities": ["Bengaluru", "Mysuru", "Mangalore", "Hubballi", "Belagavi"],
      "portals": {
        "seva_primary": {
          "name": "Seva Sindhu",
          "type": "unified_services",
          "url_home": "https://sevasindhu.karnataka.gov.in/",
          "url_services": "https://sevasindhuservices.karnataka.gov.in/",
          "urn_pattern_key": "generic_portal_ref"
        },
        "vehicle_parivahan": {
          "name": "Parivahan Vehicle Services",
          "type": "central_transport",
          "url_home": "https://parivahan.gov.in/",
          "urn_pattern_key": "generic_portal_ref"
        }
      },
      "domicile": {
        "via_portal": "Seva Sindhu",
        "prerequisites": [
          "id_proof_standard",
          "address_proof_standard",
          "domicile_affidavit",
          "education_records_long_stay"
        ],
        "notes": "Often asks for domicile/self-declaration affidavit and, for students, school/college certificates to prove stay in Karnataka.",
        "timeline_key": "domicile_certificate"
      },
      "rent": {
        "online_primary": {
          "name": "Kaveri Online Services",
          "url": "https://kaverionline.karnataka.gov.in",
          "notes": "Use for e-stamping and some registrations; user logs in, selects document type (leave & licence / rent), pays stamp duty online."
        },
        "offline_fallback": {
          "enabled": true,
          "prerequisites": ["offline_rent_ka_mh"],
          "notes": "If landlord insists on offline, visit a registered stamp vendor/document writer in areas like Koramangala/HSR. They will print a rent agreement on ₹100+ stamp paper in ~10–15 minutes."
        }
      }
    },

    "MH": {
      "name": "Maharashtra",
      "pattern": "unified_e_district_hybrid",
      "job_cities": ["Mumbai", "Pune", "Nashik", "Nagpur"],
      "portals": {
        "aaple_sarkar": {
          "name": "Aaple Sarkar",
          "type": "citizen_services",
          "url_home": "https://aaplesarkar.mahaonline.gov.in/en",
          "url_register": "https://aaplesarkar.mahaonline.gov.in/en/Registration/Register",
          "url_services": "https://aaplesarkar.mahaonline.gov.in/en/CommonForm/ViewAllServices",
          "urn_pattern_key": "generic_portal_ref"
        }
      },
      "domicile": {
        "via_portal": "Aaple Sarkar",
        "prerequisites": [
          "id_proof_standard",
          "address_proof_standard",
          "education_records_long_stay",
          "employment_proof"
        ],
        "notes": "Beyond Aadhaar/PAN, often expects proof of long-term stay such as school certificates, property records, or employment documents.",
        "timeline_key": "domicile_certificate"
      },
      "rent": {
        "online_primary": {
          "name": "IGR Maharashtra – e-Registration (Leave & License)",
          "url": "https://efilingigr.maharashtra.gov.in/ereg/",
          "notes": "Use for online Leave & License registration in cities like Pune/Mumbai; requires log-in, party details, property details, biometrics when applicable."
        },
        "offline_fallback": {
          "enabled": true,
          "prerequisites": ["offline_rent_ka_mh"],
          "notes": "Many smaller rentals still use physical stamp paper via local deed writers/stamp vendors; state law recognises e-registration as the preferred route."
        }
      }
    },

    "KL": {
      "name": "Kerala",
      "pattern": "e_district_plus_cscenters",
      "job_cities": ["Kochi", "Thiruvananthapuram", "Kozhikode"],
      "portals": {
        "edistrict": {
          "name": "eDistrict Kerala",
          "type": "e_district",
          "url_home": "https://edistrict.kerala.gov.in",
          "urn_pattern_key": "generic_portal_ref"
        },
        "akshaya": {
          "name": "Akshaya Centres",
          "type": "assisted_application",
          "url_info": "https://www.citizennest.com/guide/kerala-edistrict-certificate"
        }
      },
      "domicile": {
        "via_portal": "eDistrict Kerala / Akshaya",
        "prerequisites": [
          "id_proof_standard",
          "address_proof_standard",
          "education_records_long_stay"
        ],
        "notes": "Applications can be filed online via eDistrict or through Akshaya centres, which submit on behalf of the citizen.",
        "timeline_key": "domicile_certificate"
      }
    },

    "UP": {
      "name": "Uttar Pradesh",
      "pattern": "e_district",
      "job_cities": ["Noida", "Lucknow", "Ghaziabad"],
      "portals": {
        "edistrict": {
          "name": "eDistrict UP",
          "type": "e_district",
