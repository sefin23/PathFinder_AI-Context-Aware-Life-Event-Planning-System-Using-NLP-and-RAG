        "janhit": {
          "name": "Janhit Guarantee Services List",
          "type": "services_list",
          "url_home": "https://upcmo.up.nic.in/janhit.htm"
        }
      },
      "domicile": {
        "via_portal": "eDistrict UP",
        "prerequisites": [
          "id_proof_standard",
          "address_proof_standard",
          "education_records_long_stay"
        ],
        "notes": "May additionally require school certificates or enquiry/verification reports from local authorities to prove long-term residence.",
        "timeline_key": "domicile_certificate"
      }
    },

    "HR": {
      "name": "Haryana",
      "pattern": "unified_seva",
      "job_cities": ["Gurgaon", "Gurugram"],
      "portals": {
        "antyodaya_saral": {
          "name": "Antyodaya SARAL Haryana",
          "type": "unified_services",
