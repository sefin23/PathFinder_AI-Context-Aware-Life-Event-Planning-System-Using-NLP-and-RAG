          "url_info_gurugram": "https://gurugram.gov.in/service/antyodaya-saral/",
          "urn_pattern_key": "generic_portal_ref"
        }
      }
    },

    "TN": {
      "name": "Tamil Nadu",
      "pattern": "e_district_plus_cscenters",
      "job_cities": ["Chennai", "Coimbatore", "Madurai"],
      "portals": {
        "tnega_esevai": {
          "name": "TNeGA e-Sevai",
          "type": "e_district",
          "url_info": "https://services.india.gov.in/service/detail/tamil-nadu-e-sevai-portal-tnega",
          "url_config": "https://serviceonline.gov.in/configuretn",
          "urn_pattern_key": "generic_portal_ref"
        }
      }
    },
    "DL": {
      "name": "Delhi",
      "pattern": "e_district",
      "job_cities": ["Delhi", "New Delhi"],
      "portals": {
        "edistrict": {
          "name": "e-District Delhi",
          "type": "e_district",
          "url_home": "https://edistrict.delhigovt.nic.in/",
          "urn_pattern_key": "generic_portal_ref"
        }
      },
      "domicile": {
        "via_portal": "e-District Delhi",
        "prerequisites": [
          "id_proof_standard",
          "address_proof_standard",
          "education_records_long_stay"
        ],
        "notes": "Delhi domicile often requires 3+ years of residence proof. Rent agreements and school records are key.",
        "timeline_key": "domicile_certificate"
      }
    }
  },

